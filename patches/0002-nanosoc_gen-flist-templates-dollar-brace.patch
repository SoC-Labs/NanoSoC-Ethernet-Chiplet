--- a/soc_model/backends/lint.py
+++ b/soc_model/backends/lint.py
@@ -35,12 +35,13 @@
         self._visited: set = set()
 
     def _expand_vars(self, line: str) -> str:
-        """Expand $(VAR) and $VAR references using the environment."""
-        # Handle $(VAR) style
+        """Expand $(VAR) and ${VAR} references using the environment."""
+        # Accept both Makefile-style $(VAR) and shell/VCS-style ${VAR}; an
+        # unknown name is left verbatim so a downstream tool can still see it.
         def _repl(m):
-            var = m.group(1)
+            var = m.group(1) or m.group(2)
             return self.env.get(var, m.group(0))
-        return re.sub(r'\$\((\w+)\)', _repl, line)
+        return re.sub(r'\$\((\w+)\)|\$\{(\w+)\}', _repl, line)
 
     def parse(self, flist_path: str):
         """Parse a .flist file, recursively following -f includes."""
